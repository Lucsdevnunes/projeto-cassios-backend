# Database Configuration (Supabase PostgreSQL Connection)
# Direct connection string or transaction pooler url
DATABASE_URL="postgresql://postgres.[your-project-id]:[your-db-password]@aws-0-[your-region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Server Port
PORT=3001

# Authentication
JWT_SECRET="generate-a-long-secure-random-string-here-for-production"

# Frontend Integration
FRONTEND_URL="https://sistema.emporiodo-ar.com.br"
ALLOWED_ORIGINS="https://sistema.emporiodo-ar.com.br"

# Supabase Storage S3-Compatible API Configuration
# Get these from your Supabase Dashboard: Settings -> API -> S3 Connection
SUPABASE_URL="https://[your-project-id].supabase.co"
AWS_ACCESS_KEY_ID="[your-s3-access-key-id]"
AWS_SECRET_ACCESS_KEY="[your-s3-secret-access-key]"
AWS_REGION="[your-supabase-project-region-e.g-us-east-1]"
AWS_S3_ENDPOINT="https://[your-project-id].supabase.co/storage/v1/s3"
AWS_BUCKET_NAME="uploads"
